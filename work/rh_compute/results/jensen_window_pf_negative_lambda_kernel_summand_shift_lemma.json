      "diagnostics": null,
      "formula": "M_(k,n)(-T)=2*n^(-1/2)*integral_(a_n)^infinity (v-a_n)^(2k)*exp(-T*(v-a_n)^2)*phi_1(v)dv",
      "gap": null,
