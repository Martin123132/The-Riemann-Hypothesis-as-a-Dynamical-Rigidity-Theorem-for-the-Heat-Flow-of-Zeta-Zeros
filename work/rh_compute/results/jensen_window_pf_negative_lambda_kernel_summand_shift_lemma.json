      "diagnostics": null,
      "formula": "exp(4*a_n)=n^2, n^(-1/2)*exp(9*a_n)=n^4, n^(-1/2)*exp(5*a_n)=n^2",
      "gap": null,
      "id": "ksl_02_exact_summand_shift",
      "proof_boundary": "Exact algebra for every integer n>=1 and real u.",
