      "role": "exact_identity",
      "readiness": "available_exact",
      "claim": "Degree scaling inserts the falling-factorial multiplier into the entire-function coefficients.",
      "formula": "J_(D,n,lambda)(z/D)=sum_(j=0)^D ((D)_j/D^j)*A_(n+j)(lambda)*z^j/j!",
