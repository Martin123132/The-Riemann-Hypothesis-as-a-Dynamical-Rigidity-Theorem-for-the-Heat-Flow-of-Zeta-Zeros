    k2 = vel(z + 0.5 * ds * k1)
    k3 = vel(z + 0.5 * ds * k2)
    k4 = vel(z + ds * k3)
    return z + (ds / 6.0) * (k1 + 2*k2 + 2*k3 + k4)
def track(z0, s_vals):
    hist = np.zeros((len(s_vals), len(z0)), dtype=float)
    hist[0] = z0.copy()
    z = z0.copy()
    for k in range(1, len(s_vals)):
        z = rk4_repulsive(z, s_vals[k] - s_vals[k-1])
        hist[k] = z
    return hist
if __name__ == "__main__":
    print("splitting.py")
    print("=" * 72)
    print("Reduced flow: dt_i/ds = +2 sum_{j!=i} 1/(t_i-t_j)")
    print()
    # Test 1: isolated pair exact law
    sep0 = 0.5
    s_vals = np.linspace(0.0, 1.0, 400)
    hist = track(np.array([-sep0/2, +sep0/2], dtype=float), s_vals)
    sep_num = hist[:, 1] - hist[:, 0]
    sep_th  = np.sqrt(sep0**2 + 8.0 * s_vals)  # corrected sign
