RG_CLOSURE = r'''"""
rg_closure.py
=============
Reproduces:
  - rank-2 reduced-flow manifold
  - Hadamard alignment of mode 1
  - approximate 2x2 closure in coefficient space
  - α(0) Δ̄ universality across moderate heights
Convention
----------
Reduced repulsive flow parameter s >= 0:
    dt_i/ds = +2 * sum_{j!=i} 1/(t_i - t_j)
This is an abstract reduced flow used consistently throughout the package.
It is not asserted here that s is identical to the physical heat-flow time.
Claims checked
--------------
1. S1/S2 large, S2/S3 large       (rank-2 dominance)
2. mode1 · v_Had > 0.998          (Hadamard alignment)
3. mean R² > 0.997               (velocity lies in span{e1,e2})
4. closure error < 10%            (approximate 2x2 closure)
5. α(0)Δ̄ approximately constant
Runtime: typically under ~10 minutes depending on machine
"""
import mpmath
import numpy as np
from scipy.linalg import svd
mpmath.mp.dps = 25
T_VALS    = [50, 100, 200, 300, 500]
N_ZEROS   = 12
S_MAX     = 0.04
N_S       = 100
def find_zeros(T, n, span=25.0):
    ts = np.linspace(T - span, T + span, 8000)
    zv = np.array([float(mpmath.siegelz(t)) for t in ts])
    z0 = []
    for i in range(len(zv) - 1):
        if zv[i] * zv[i + 1] < 0:
            root = float(mpmath.findroot(mpmath.siegelz, (ts[i], ts[i+1]), solver='illinois'))
            z0.append(root)
    z0 = sorted(z0)
    mid = len(z0) // 2
    return np.array(z0[mid - n//2 : mid + n//2], dtype=float)
def rk4_repulsive(z, ds):
    def vel(x):
        n = len(x)
        v = np.zeros(n, dtype=float)
        for i in range(n):
            for j in range(n):
                if i != j:
                    d = x[i] - x[j]
                    if abs(d) > 1e-12:
                        v[i] += 2.0 / d
        return v
    k1 = vel(z)
    k2 = vel(z + 0.5 * ds * k1)
    k3 = vel(z + 0.5 * ds * k2)
    k4 = vel(z + ds * k3)
    return z + (ds / 6.0) * (k1 + 2*k2 + 2*k3 + k4)
def hadamard_direction(z0):
    n = len(z0)
    vh = np.zeros(n, dtype=float)
    for i in range(n):
        for j in range(n):
            if i != j:
                vh[i] += 2.0 / (z0[i] - z0[j])
    vh -= vh.mean()
    return vh / np.linalg.norm(vh)
def density_direction(z0, e1):
    n = len(z0)
    d = np.diff(z0)
    vd = np.zeros(n, dtype=float)
    for i in range(1, n - 1):
        di = 0.5 * (z0[i+1] - z0[i-1])
        if di > 1e-12:
            vd[i] = -(d[i] - d[i-1]) / (2.0 * di**2)
    if len(d) > 1:
        vd[0]  = -(d[1]  - d[0])  / (2.0 * d[0]**2)
        vd[-1] = -(d[-1] - d[-2]) / (2.0 * d[-1]**2)
    vd -= vd.mean()
    vd -= np.dot(vd, e1) * e1
    nrm = np.linalg.norm(vd)
    if nrm < 1e-12:
        return np.zeros_like(vd)
    return vd / nrm
def run_one(T):
    z0 = find_zeros(T, N_ZEROS)
    D  = np.diff(z0).mean()
    e1 = hadamard_direction(z0)
    e2 = density_direction(z0, e1)
    s_vals = np.exp(np.linspace(np.log(1e-4), np.log(S_MAX), N_S))
    s_full = np.concatenate([[0.0], s_vals])
    hist = np.zeros((len(s_full), len(z0)), dtype=float)
    hist[0] = z0.copy()
    z = z0.copy()
    for k in range(1, len(s_full)):
        z = rk4_repulsive(z, s_full[k] - s_full[k-1])
        hist[k] = z
    V = np.zeros((len(z0), N_S), dtype=float)
    for k, s in enumerate(s_vals):
        col = (hist[k+1] - z0) / s
        col -= col.mean()
        V[:, k] = col
    U, S, _ = svd(V, full_matrices=False)
    cos1 = abs(np.dot(U[:, 0], e1))
    r2s = []
    alpha = []
    beta  = []
    for k in range(N_S):
        vk = V[:, k]
        nrm = np.linalg.norm(vk)
        if nrm > 1e-15:
            proj = np.dot(vk, e1) * e1 + np.dot(vk, e2) * e2
            r2s.append(1.0 - (np.linalg.norm(vk - proj) / nrm)**2)
        alpha.append(np.dot(vk, e1))
        beta.append(np.dot(vk, e2))
    alpha = np.array(alpha)
    beta  = np.array(beta)
    if alpha.mean() < 0:
        alpha = -alpha
        beta  = -beta
    logs = np.log(s_vals)
    i0, i1 = N_S // 10, 9 * N_S // 10
    da, db, av, bv = [], [], [], []
    for k in range(i0 + 1, i1 - 1):
        dl = logs[k+1] - logs[k-1]
        if dl <= 1e-15:
            continue
        da.append((alpha[k+1] - alpha[k-1]) / dl)
        db.append((beta[k+1]  - beta[k-1])  / dl)
        av.append(alpha[k])
        bv.append(beta[k])
    da = np.array(da); db = np.array(db)
    av = np.array(av); bv = np.array(bv)
    A = np.zeros((2 * len(av), 4), dtype=float)
    b = np.zeros(2 * len(av), dtype=float)
    for k in range(len(av)):
        A[2*k,   :2] = [av[k], bv[k]]
        A[2*k+1, 2:] = [av[k], bv[k]]
        b[2*k]   = da[k]
        b[2*k+1] = db[k]
    Bflat, _, _, _ = np.linalg.lstsq(A, b, rcond=None)
    B = Bflat.reshape(2, 2)
    err = np.linalg.norm(b - A @ Bflat) / (np.linalg.norm(b) + 1e-30)
    return {
        "T": T,
        "D": D,
        "S": S,
        "cos1": cos1,
        "r2": float(np.mean(r2s)),
        "alpha0": float(alpha[0]),
        "B": B,
        "err": float(err),
    }
if __name__ == "__main__":
    print("rg_closure.py")
    print("=" * 72)
    print("Reduced flow: dt_i/ds = +2 sum_{j!=i} 1/(t_i-t_j)")
    print()
    hdr = f"{'T':>6} {'Δ̄':>8} {'S1/S2':>10} {'S2/S3':>10} {'cos1':>10} {'R²':>10} {'B11':>10} {'err':>10}"
    print(hdr)
    print("-" * len(hdr))
    results = []
    for T in T_VALS:
        r = run_one(T)
        results.append(r)
        S = r["S"]
        print(f"{T:6d} {r['D']:8.4f} {S[0]/S[1]:10.2f} {S[1]/S[2]:10.2f} {r['cos1']:10.6f} {r['r2']:10.6f} {r['B'][1,1]:10.4f} {r['err']:10.4f}")
    prod = np.array([abs(r["alpha0"]) * r["D"] for r in results])
    print()
    print(f"α(0)Δ̄ = {prod.mean():.3f} ± {prod.std():.3f}  (CV = {prod.std()/prod.mean():.3f})")
    assert all(r["S"][0] / r["S"][1] > 10 for r in results), "FAIL: weak S1/S2 gap"
    assert all(r["cos1"] > 0.998 for r in results), "FAIL: weak Hadamard alignment"
    assert all(r["r2"] > 0.997 for r in results), "FAIL: poor rank-2 capture"
    assert all(r["err"] < 0.10 for r in results), "FAIL: closure error too large"
    print("ALL ASSERTIONS PASSED")
'''
